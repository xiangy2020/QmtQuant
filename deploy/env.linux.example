# QmtQuant Linux 服务器环境配置模板
# 使用方法：复制本文件为 .env，并填写必要配置项
#   cp deploy/env.linux.example .env
#   vim .env   # 填写 XQSHARE_REMOTE_HOST

# ==================== xqshare 客户端连接配置 ====================

# [必填] Windows 机器的内网 IP 地址（运行 miniQMT + xqshare server 的机器）
# 示例：XQSHARE_REMOTE_HOST=192.168.1.100
XQSHARE_REMOTE_HOST=

# [可选] xqshare server 监听端口，默认 18812
# 与 Windows 机器上 xqshare server 的端口保持一致
XQSHARE_REMOTE_PORT=18812

# ==================== data-api 服务配置 ====================

# [可选] data-api HTTP 服务监听地址
# 0.0.0.0 表示监听所有网络接口，允许局域网内其他机器访问
# 如需仅本机访问，改为 127.0.0.1
DATA_API_HOST=0.0.0.0

# [可选] data-api HTTP 服务监听端口，默认 8765
# 如果 8765 端口已被占用，可修改为其他端口（如 9000）
DATA_API_PORT=8765

# ==================== QMT 配置（Linux 上通常不需要修改）====================

# QMT 用户数据目录（Windows 路径，Linux 上通过 xqshare 远程访问，无需本地路径）
# QMT_USERDATA_PATH=

# QMT 账户 ID（如需使用交易功能时填写）
# QMT_ACCOUNT_ID=

# ==================== 日志配置 ====================

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
